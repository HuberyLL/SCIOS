SEMANTIC_SCHOLAR_API_KEY=
TAVILY_API_KEY=

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
# Multi-provider examples (via litellm):
# OpenAI (default):      LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o
# Anthropic:             LLM_BASE_URL=                                      LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
# Gemini:                LLM_BASE_URL=                                      LLM_MODEL=gemini/gemini-1.5-pro
# OpenAI-compatible API: LLM_BASE_URL=https://api.deepseek.com/v1           LLM_MODEL=deepseek-chat

DB_PATH=../data/scios.db

# Assistant mode (optional overrides)
# ASSISTANT_MODEL=          # defaults to LLM_MODEL
# ASSISTANT_SYSTEM_PROMPT=  # defaults to built-in prompt
# ASSISTANT_MAX_TOOL_ROUNDS=10
# ASSISTANT_MAX_CONTEXT_TOKENS=8000
# ASSISTANT_MEMORY_MAX_ITEMS=20
# ASSISTANT_MEMORY_MAX_TOKENS=1200
# ASSISTANT_WORKSPACE_DIR=workspace

# Monitoring scheduler — cron mode (production)
MONITORING_CRON_HOUR=8
MONITORING_CRON_MINUTE=0
# Monitoring scheduler — interval mode (testing, overrides cron if set)
# MONITORING_INTERVAL_MINUTES=5

# Multi-source paper search (optional)
CORE_API_KEY=
UNPAYWALL_EMAIL=
DOAJ_API_KEY=
CROSSREF_MAILTO=
OPENALEX_MAILTO=

# Source routing — Planner-hints-first intelligent routing
SOURCE_ROUTING_ENABLED=true
SOURCE_ROUTING_CONFIDENCE_THRESHOLD=0.6
SOURCE_ROUTING_MAX_SOURCES=3
SOURCE_ROUTING_STAGE_B_ENABLED=true
SOURCE_ROUTING_MIN_PAPERS_STAGE_B=5

# Synthesizer — max papers included in the LLM prompt
SYNTHESIZER_MAX_PAPERS=40

# Email notification (SMTP)
SMTP_SERVER=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=
